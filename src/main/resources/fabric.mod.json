{
  "schemaVersion": 1,
  "id": "murdermysteryhelper",
  "version": "${version}",
  "name": "MurderMysteryHelper",
  "description": "A helper to play MurderMystery - detects murderers with swords and detectives with bows",
  "authors": [
    "chxjj"
  ],
  "contact": {
    "homepage": "https://github.com/xjjakm/MurderMysteryHelper",
    "sources": "https://github.com/xjjakm/MurderMysteryHelper",
    "issues": "https://github.com/xjjakm/MurderMysteryHelper/issues"
  },
  "license": "GPL-3.0",
  "icon": "assets/mh/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "org.chxjj.mh.client.murdermysteryhelperClient"
    ],
    "main": [
      "org.chxjj.mh.main.murdermysteryhelper"
    ],
    "modmenu": [
      "org.chxjj.mh.client.config"
    ]
  },
  "mixins": [
    "murdermysteryhelper.mixins.json",
    {
      "config": "murdermysteryhelper.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${kotlin_loader_version}",
    "fabric-api": "*",
    "yet_another_config_lib_v3": ">=3.9.5",
    "minecraft": "${minecraft_version}",
    "modmenu": ">=${modmenu_version}"
  }
}
